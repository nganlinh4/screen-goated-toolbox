{
  "version": 1,
  "cases": [
    {
      "name": "realtime_skips_existing_history_on_first_enable",
      "initial_committed_text": "Sentence one. Sentence two. Active sentence tail with more words",
      "initial_state": {
        "spoken_length": 0,
        "queued_length": 0
      },
      "action": "enable_realtime",
      "expected": {
        "spoken_length": 27,
        "queued_length": 62,
        "queued_segments": [
          " Active sentence tail with more words"
        ]
      }
    },
    {
      "name": "preview_interrupt_replays_unsent_realtime_tail",
      "initial_committed_text": "Sentence one. Sentence two. Active sentence tail with more words",
      "initial_state": {
        "spoken_length": 13,
        "queued_length": 62
      },
      "pending_realtime_requests": [
        {
          "request_id": 41,
          "end_offset": 62
        }
      ],
      "action": "preview_interrupt",
      "expected": {
        "spoken_length": 13,
        "queued_length": 13,
        "queued_segments": []
      }
    },
    {
      "name": "google_translate_fast_is_coerced_to_normal",
      "initial_settings": {
        "method": "GEMINI_LIVE",
        "speed_preset": "FAST"
      },
      "action": "switch_method_to_google_translate",
      "expected": {
        "method": "GOOGLE_TRANSLATE",
        "speed_preset": "NORMAL"
      }
    },
    {
      "name": "google_translate_settings_preview_interrupts_current_speech",
      "initial_settings": {
        "method": "GOOGLE_TRANSLATE",
        "speed_preset": "NORMAL"
      },
      "action": "preview_interrupt",
      "expected": {
        "request_mode": "INTERRUPT",
        "preview_text_source": "locale.tts_preview_texts"
      }
    },
    {
      "name": "edge_ssml_volume_is_not_applied_again_by_player",
      "initial_settings": {
        "method": "EDGE_TTS",
        "edge_volume": 40
      },
      "action": "play_edge_tts_request",
      "expected": {
        "ssml_volume_percent": 40,
        "playback_volume_percent": 100
      }
    },
    {
      "name": "android_visible_tts_methods_follow_windows_selector",
      "android_selector_methods": [
        "GEMINI_LIVE",
        "EDGE_TTS",
        "GOOGLE_TRANSLATE"
      ],
      "android_excluded_windows_local_methods": [
        "STEP_AUDIO_EDITX",
        "MAGPIE_MULTILINGUAL",
        "KOKORO",
        "SUPERTONIC",
        "VIENEU_TTS"
      ],
      "legacy_hidden_methods": [
        "VOXTRAL_TTS"
      ]
    },
    {
      "name": "legacy_voxtral_tts_coerces_to_android_supported_method",
      "initial_settings": {
        "method": "VOXTRAL_TTS"
      },
      "expected": {
        "method": "GEMINI_LIVE"
      }
    },
    {
      "name": "android_open_weight_methods_are_feature_excluded",
      "methods": [
        "STEP_AUDIO_EDITX",
        "MAGPIE_MULTILINGUAL",
        "KOKORO",
        "SUPERTONIC",
        "VIENEU_TTS",
        "VOXTRAL_TTS"
      ],
      "expected_normalized_method": "GEMINI_LIVE"
    },
    {
      "name": "android_open_weight_settings_are_not_serialized",
      "forbidden_settings_fields": [
        "kokoroSettings",
        "stepAudioSettings",
        "magpieSettings",
        "supertonicSettings",
        "vieneuSettings",
        "voxtralSettings"
      ]
    }
  ]
}
