{
  "schemaVersion": 1,
  "tool": "image-to-svg",
  "states": [
    "draft",
    "queued",
    "preparing",
    "generating",
    "finalizing",
    "done",
    "failed",
    "cancelled"
  ],
  "models": {
    "simple": {
      "remoteModel": "Classic",
      "creditCost": 2
    },
    "detail": {
      "remoteModel": "Ultra",
      "creditCost": 4
    }
  },
  "limits": {
    "maximumParallelJobs": 2,
    "maximumConcurrentPreparations": 1,
    "minimumPreparationIntervalSeconds": 60,
    "preparedWorkspaces": 2,
    "minimumReusableCredits": 4
  },
  "viewer": {
    "preserveIntrinsicRatio": true,
    "animateAllPaths": true,
    "adaptiveOverlappingAnimation": true,
    "editableShapes": ["path", "rect", "circle", "ellipse", "polygon", "polyline", "line"]
  },
  "history": {
    "requireExistingOutput": true,
    "renameMutatesOutput": true,
    "deleteMutatesOutput": true
  },
  "androidSurface": {
    "shell": "native_compose_m3e",
    "resultRenderer": "sandboxed_svg_document",
    "progressPreview": "depth_anything_3_six_bins",
    "previewInputSide": 518,
    "previewBlocksGeneration": false,
    "previewSetupVisible": false,
    "preparationProgressMaximumPercent": 18,
    "diagnostics": "bounded_privacy_safe_journal",
    "backgroundAutomationVisible": false
  },
  "distribution": {
    "fullSupported": true,
    "playSupported": true,
    "downloadExecutableCode": false
  }
}
