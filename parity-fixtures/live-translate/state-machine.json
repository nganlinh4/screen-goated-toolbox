{
  "version": 2,
  "cases": [
    {
      "name": "finished request commits finalized bytes and replaces draft",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "hello. tail",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 11,
            "finalizedSourceEnd": 6,
            "pendingSource": "hello. tail",
            "finalizedSource": "hello.",
            "draftSource": " tail",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "applyTranslationResponse",
          "response": {
            "patches": [
              {
                "sourceStart": 0,
                "sourceEnd": 6,
                "state": "final",
                "translation": "hola."
              },
              {
                "sourceStart": 6,
                "sourceEnd": 11,
                "state": "draft",
                "translation": "cola"
              }
            ]
          },
          "atMs": 140
        }
      ],
      "expectedState": {
        "fullTranscript": "hello. tail",
        "displayTranscript": "hello. tail",
        "lastCommittedPos": 6,
        "lastProcessedLen": 11,
        "committedTranslation": "hola.",
        "uncommittedTranslation": "cola",
        "uncommittedSourceStart": 6,
        "uncommittedSourceEnd": 11,
        "displayTranslation": "hola. cola",
        "translationHistory": [
          {
            "source": "hello.",
            "translation": "hola."
          }
        ]
      }
    },
    {
      "name": "unfinished tail stays draft until force commit",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "hello tail",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 10,
            "finalizedSourceEnd": 0,
            "pendingSource": "hello tail",
            "finalizedSource": "",
            "draftSource": "hello tail",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "applyTranslationResponse",
          "response": {
            "patches": [
              {
                "sourceStart": 0,
                "sourceEnd": 10,
                "state": "draft",
                "translation": "hola cola"
              }
            ]
          },
          "atMs": 150
        },
        {
          "type": "forceCommitAll"
        }
      ],
      "expectedState": {
        "fullTranscript": "hello tail",
        "displayTranscript": "hello tail",
        "lastCommittedPos": 10,
        "lastProcessedLen": 10,
        "committedTranslation": "hola cola",
        "uncommittedTranslation": "",
        "uncommittedSourceStart": 10,
        "uncommittedSourceEnd": 10,
        "displayTranslation": "hola cola",
        "translationHistory": [
          {
            "source": "hello tail",
            "translation": "hola cola"
          }
        ]
      }
    },
    {
      "name": "next request reuses untranslated tail with new source end",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "one. two",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 8,
            "finalizedSourceEnd": 4,
            "pendingSource": "one. two",
            "finalizedSource": "one.",
            "draftSource": " two",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "applyTranslationResponse",
          "response": {
            "patches": [
              {
                "sourceStart": 0,
                "sourceEnd": 4,
                "state": "final",
                "translation": "uno."
              },
              {
                "sourceStart": 4,
                "sourceEnd": 8,
                "state": "draft",
                "translation": "dos"
              }
            ]
          },
          "atMs": 120
        },
        {
          "type": "appendTranscript",
          "text": "!",
          "atMs": 180
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 4,
            "sourceEnd": 9,
            "finalizedSourceEnd": 9,
            "pendingSource": " two!",
            "finalizedSource": " two!",
            "draftSource": "",
            "previousDraftTranslation": ""
          }
        }
      ],
      "expectedState": {
        "fullTranscript": "one. two!",
        "displayTranscript": "one. two!",
        "lastCommittedPos": 4,
        "lastProcessedLen": 8,
        "committedTranslation": "uno.",
        "uncommittedTranslation": "dos",
        "uncommittedSourceStart": 4,
        "uncommittedSourceEnd": 8,
        "displayTranslation": "uno. dos",
        "translationHistory": [
          {
            "source": "one.",
            "translation": "uno."
          }
        ]
      }
    },
    {
      "name": "language change clears translation history only",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "carry on",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 8,
            "finalizedSourceEnd": 0,
            "pendingSource": "carry on",
            "finalizedSource": "",
            "draftSource": "carry on",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "applyTranslationResponse",
          "response": {
            "patches": [
              {
                "sourceStart": 0,
                "sourceEnd": 8,
                "state": "draft",
                "translation": "sigue"
              }
            ]
          },
          "atMs": 140
        },
        {
          "type": "forceCommitAll"
        },
        {
          "type": "clearTranslationHistory"
        }
      ],
      "expectedState": {
        "fullTranscript": "carry on",
        "displayTranscript": "carry on",
        "lastCommittedPos": 8,
        "lastProcessedLen": 8,
        "committedTranslation": "sigue",
        "uncommittedTranslation": "",
        "uncommittedSourceStart": 8,
        "uncommittedSourceEnd": 8,
        "displayTranslation": "sigue",
        "translationHistory": []
      }
    },
    {
      "name": "same transcript can be retried before success",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "steady stream",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 13,
            "finalizedSourceEnd": 0,
            "pendingSource": "steady stream",
            "finalizedSource": "",
            "draftSource": "steady stream",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 13,
            "finalizedSourceEnd": 0,
            "pendingSource": "steady stream",
            "finalizedSource": "",
            "draftSource": "steady stream",
            "previousDraftTranslation": ""
          }
        }
      ],
      "expectedState": {
        "fullTranscript": "steady stream",
        "displayTranscript": "steady stream",
        "lastCommittedPos": 0,
        "lastProcessedLen": 0,
        "committedTranslation": "",
        "uncommittedTranslation": "",
        "uncommittedSourceStart": 0,
        "uncommittedSourceEnd": 0,
        "displayTranslation": "",
        "translationHistory": []
      }
    },
    {
      "name": "force commit only covers current draft source snapshot",
      "steps": [
        {
          "type": "appendTranscript",
          "text": "old text",
          "atMs": 100
        },
        {
          "type": "claimTranslationRequest",
          "expectedRequest": {
            "sourceStart": 0,
            "sourceEnd": 8,
            "finalizedSourceEnd": 0,
            "pendingSource": "old text",
            "finalizedSource": "",
            "draftSource": "old text",
            "previousDraftTranslation": ""
          }
        },
        {
          "type": "applyTranslationResponse",
          "response": {
            "patches": [
              {
                "sourceStart": 0,
                "sourceEnd": 8,
                "state": "draft",
                "translation": "van ban cu"
              }
            ]
          },
          "atMs": 140
        },
        {
          "type": "appendTranscript",
          "text": " plus",
          "atMs": 180
        },
        {
          "type": "forceCommitAll"
        }
      ],
      "expectedState": {
        "fullTranscript": "old text plus",
        "displayTranscript": "old text plus",
        "lastCommittedPos": 8,
        "lastProcessedLen": 8,
        "committedTranslation": "van ban cu",
        "uncommittedTranslation": "",
        "uncommittedSourceStart": 8,
        "uncommittedSourceEnd": 8,
        "displayTranslation": "van ban cu",
        "translationHistory": [
          {
            "source": "old text",
            "translation": "van ban cu"
          }
        ]
      }
    }
  ]
}
