{
  "version": 1,
  "defaults": {
    "audioSource": "device",
    "targetLanguage": "Vietnamese",
    "translationModel": "text-llm",
    "translationApiModel": "",
    "transcriptionModel": "gemini-live-s2s",
    "fontSize": 16,
    "ttsEnabled": false,
    "ttsSpeed": 100,
    "ttsAutoSpeed": true,
    "ttsVolume": 100
  },
  "requiredModels": {
    "translationProviders": [
      "text-llm",
      "google-gtx"
    ],
    "windowsTranscriptionProviders": [
      "gemini-live-audio",
      "gemini-live-s2s",
      "parakeet",
      "qwen3-asr-0.6b",
      "qwen3-asr-1.7b",
      "zipformer"
    ],
    "androidTranscriptionProviders": [
      "gemini-live-audio",
      "gemini-live-s2s",
      "parakeet",
      "moonshine-tiny-streaming",
      "moonshine-small-streaming",
      "moonshine-medium-streaming",
      "zipformer"
    ],
    "androidUnavailableTranscriptionProviders": [
      "parakeet"
    ]
  },
  "requiredControls": {
    "transcriptionPane": [
      "waveform-canvas",
      "audio-source-toggle",
      "transcription-model-toggle",
      "copy",
      "font-minus",
      "font-plus",
      "toggle-transcription",
      "toggle-translation",
      "collapse-chevron"
    ],
    "translationPane": [
      "tts-read",
      "translation-model-toggle",
      "language-select",
      "copy",
      "font-minus",
      "font-plus",
      "toggle-transcription",
      "toggle-translation",
      "collapse-chevron"
    ]
  },
  "requiredVisuals": {
    "fontFamily": "Google Sans Flex",
    "translationHeaderText": "absent",
    "mobileResizeGesture": "pinch",
    "mobileOverlayWindows": "detached",
    "portraitLayout": "stacked-default-detached",
    "landscapeLayout": "side-by-side-default-detached",
    "chevronConsumesLayoutSpace": false,
    "headerOverflowBehavior": "horizontal-swipe",
    "headerScrollRetention": "preserve-on-runtime-control-taps",
    "headerStateSync": "discrete-js-no-html-reload",
    "textRendererContract": "windows-fulltext-previousFullText-commitAdvance",
    "overlayLocaleSource": "active-ui-language-bundle",
    "overlayLocaleRefresh": "live-on-ui-language-change",
    "roundedWindowMask": true,
    "languagePicker": "native-overlay",
    "androidDeviceTtsIsolation": "non-capturable-no-app-picker",
    "androidTtsSettingsApplyToUnreadText": true,
    "androidTtsRequestsTransientDuckFocus": true,
    "ttsDisplayedSpeedSource": "runtime-effective-while-speaking",
    "localeUpdatePath": "discrete-js-no-html-reload",
    "dismissDragPersistence": "restore-pre-drag"
  }
}
