{
  "surface": "preset_result_overlay",
  "render_mode": "markdown_only",
  "window_creation": "precreate_before_result_text",
  "windows": [
    {
      "block_idx": 1,
      "show_overlay": true,
      "render_mode": "markdown_stream",
      "expected_window": true
    },
    {
      "block_idx": 2,
      "show_overlay": false,
      "render_mode": "markdown_stream",
      "expected_window": false
    },
    {
      "block_idx": 3,
      "show_overlay": true,
      "render_mode": "markdown",
      "expected_window": true
    }
  ],
  "canvas": {
    "reveal_model": "tap_and_linger",
    "linger_ms": 2000,
    "unsupported_actions": [
      "edit",
      "undo",
      "redo",
      "download",
      "speaker",
      "markdown_toggle",
      "broom_group_all"
    ]
  },
  "markdown_view": {
    "font_family": "Google Sans Flex",
    "theme_source": "windows_markdown_css_rs",
    "fit_script_source": "windows_streaming_fit_impl_rs",
    "streaming_update_source": "windows_markdown_streaming_rs",
    "gridjs_enabled_for_tables": true,
    "dom_contract": "body_level_markdown_content",
    "render_mode": "markdown_plus_raw_html",
    "raw_html_supported": true,
    "theme_sync_scope": "all_preset_overlays",
    "touch_scroll_model": "two_finger_bidirectional_native_scroll",
    "raw_html_host_contract": "page_load_reinjected_overlay_shell",
    "input_adapter_media_contract": {
      "canonical_source": "windows_chain_templates_rs",
      "runtime_owner": "result_window_runtime",
      "preserve_markers": [
        "data-sgt-input-adapter-media",
        "audio-player"
      ],
      "body_chrome_policy": "disable_generic_markdown_body_chrome_for_media_docs"
    },
    "navigation_model": "native_history_plus_restore_original_surface",
    "navigation_internal_entry_policy": "restore_original_surface_and_clear_history",
    "failed_external_navigation_policy": "restore_original_surface"
  }
}
