{
  "canonical_windows_files": [
    "src/config/preset/defaults/audio.rs",
    "src/hotkey/processor.rs",
    "src/overlay/recording/mod.rs",
    "src/overlay/recording/ui.rs",
    "src/api/audio/recording.rs",
    "src/api/audio/transcription.rs"
  ],
  "recording_toggle_contract": {
    "first_launch": "start_recording",
    "second_launch_same_preset": "stop_and_submit",
    "third_launch_while_processing": "abort_and_close"
  },
  "auto_stop_thresholds": {
    "warmup_rms": 0.001,
    "speech_rms": 0.015,
    "silence_ms": 800,
    "min_speech_ms": 2000
  },
  "default_auto_stop_presets": [
    "preset_transcribe",
    "preset_fix_pronunciation",
    "preset_transcribe_retranslate",
    "preset_quicker_foreigner_reply",
    "preset_quick_ai_question",
    "preset_voice_search",
    "preset_quick_record",
    "preset_record_device"
  ],
  "recording_shell_contract": {
    "source": "windows_webview_template",
    "bridge_methods": ["resetState", "updateState", "hideState", "updateTheme"],
    "ipc_messages": ["ready", "pause_toggle", "cancel", "drag_window"]
  },
  "shared_mic_button_contract": {
    "text_input": "preset_transcribe",
    "result_canvas": "preset_transcribe",
    "preset_transcribe_prompt": "Transcribe the audio into text. Output ONLY the transcript."
  },
  "streaming_capture_contract": {
    "gemini-live-audio": "partial_transcript_during_capture",
    "parakeet-local": "partial_transcript_during_capture",
    "final_transcript_handoff": "first_audio_block_uses_precomputed_transcript",
    "streaming_auto_paste": "inject_deltas_during_capture_and_skip_final_paste_when_already_written"
  },
  "realtime_contract": {
    "launch_path": "transient_live_service_override",
    "restore_saved_config_on_stop": true
  },
  "bubble_capture_host_contract": {
    "default_foreground_mode": "specialUse",
    "mic_presets": "promote_to_microphone_then_restore",
    "device_audio_presets": "promote_to_mediaProjection_then_restore"
  },
  "auto_speak_contract": {
    "consumer": "AUTO_SPEAK",
    "first_failure_recovery": "single_retry_then_surface_error"
  }
