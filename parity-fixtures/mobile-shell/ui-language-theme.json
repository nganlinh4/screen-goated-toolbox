{
  "version": 1,
  "cases": [
    {
      "name": "theme_cycle_matches_windows_title_bar",
      "initial_theme_mode": "SYSTEM",
      "action": "cycle_theme",
      "expected_cycle": [
        "DARK",
        "LIGHT",
        "SYSTEM"
      ]
    },
    {
      "name": "ui_language_choices_match_windows_title_bar",
      "expected_language_codes": [
        "en",
        "vi",
        "ko"
      ]
    },
    {
      "name": "localized_preview_text_comes_from_ui_language_bundle",
      "voice_name": "Aoede",
      "locales": [
        {
          "ui_language": "en",
          "expected_prefix": "Hello"
        },
        {
          "ui_language": "vi",
          "expected_prefix": "Xin chào"
        },
        {
          "ui_language": "ko",
          "expected_prefix": "안녕하세요"
        }
      ]
    },
    {
      "name": "open_weight_tts_labels_come_from_ui_language_bundle",
      "locales": [
        {
          "ui_language": "en",
          "expected_voice_label": "Voice:",
          "expected_language_label": "Language (BCP-47, optional):",
          "expected_unavailable_phrase": "not available for this model on Android yet"
        },
        {
          "ui_language": "vi",
          "expected_voice_label": "Giọng đọc:",
          "expected_language_label": "Ngôn ngữ (BCP-47, tùy chọn):",
          "expected_unavailable_phrase": "chưa có trên Android"
        },
        {
          "ui_language": "ko",
          "expected_voice_label": "목소리:",
          "expected_language_label": "언어 (BCP-47, 선택 사항):",
          "expected_unavailable_phrase": "아직 Android에서 사용할 수 없습니다"
        }
      ]
    },
    {
      "name": "mobile_branding_uses_windows_app_icon_pair",
      "expected_dark_asset": "assets/app-icon-small.png",
      "expected_light_asset": "assets/app-icon-small-light.png"
    },
    {
      "name": "tools_tab_owns_scroll_and_uses_viewport_footer",
      "section": "TOOLS",
      "expected_outer_scroll_owner": false,
      "expected_viewport_footer": true
    },
    {
      "name": "nested_carousel_locks_outer_pager_for_the_full_touch_when_inner_scroll_exists",
      "touch_cases": [
        {
          "can_scroll_backward": true,
          "can_scroll_forward": false,
          "expected_lock": true
        },
        {
          "can_scroll_backward": false,
          "can_scroll_forward": true,
          "expected_lock": true
        },
        {
          "can_scroll_backward": true,
          "can_scroll_forward": true,
          "expected_lock": true
        },
        {
          "can_scroll_backward": false,
          "can_scroll_forward": false,
          "expected_lock": false
        }
      ]
    }
  ]
}
