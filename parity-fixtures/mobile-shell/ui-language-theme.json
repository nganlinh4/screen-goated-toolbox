{
  "version": 1,
  "cases": [
    {
      "name": "theme_cycle_matches_windows_title_bar",
      "initial_theme_mode": "SYSTEM",
      "action": "cycle_theme",
      "expected_cycle": [
        "DARK",
        "LIGHT",
        "SYSTEM"
      ]
    },
    {
      "name": "ui_language_choices_match_windows_title_bar",
      "expected_language_codes": [
        "en",
        "vi",
        "ko"
      ]
    },
    {
      "name": "locale_resolution_uses_explicit_code_and_falls_back_to_english",
      "cases": [
        {
          "input": "en",
          "expected_locale_code": "en"
        },
        {
          "input": "vi",
          "expected_locale_code": "vi"
        },
        {
          "input": "ko",
          "expected_locale_code": "ko"
        },
        {
          "input": "",
          "expected_locale_code": "en"
        },
        {
          "input": "fr",
          "expected_locale_code": "en"
        },
        {
          "input": "en-US",
          "expected_locale_code": "en"
        }
      ]
    },
    {
      "name": "localized_preview_text_comes_from_ui_language_bundle",
      "voice_name": "Aoede",
      "expected_template_count": 10,
      "avoid_immediate_repeat_when_multiple": true,
      "locales": [
        {
          "ui_language": "en",
          "expected_prefix": "Hello",
          "expected_first_rendered": "Hello, I am Aoede, ready to read this text for you."
        },
        {
          "ui_language": "vi",
          "expected_prefix": "Xin chào",
          "expected_first_rendered": "Xin chào, tôi là Aoede, tôi có thể đọc giúp bạn đoạn văn này."
        },
        {
          "ui_language": "ko",
          "expected_prefix": "안녕하세요",
          "expected_first_rendered": "안녕하세요, 제 이름은 Aoede입니다. 만나서 반갑습니다."
        }
      ]
    },
    {
      "name": "locale_helpers_follow_copied_sections",
      "base_locale": "en",
      "copied_section_locale": "ko",
      "expected_locale_code_after_copy": "en",
      "copied_sections": [
        "appearance",
        "help",
        "ttsVoice"
      ],
      "helpers": [
        "compact_overlay_opacity",
        "reset_defaults_done",
        "tools_help",
        "preview_selection"
      ]
    },
    {
      "name": "settings_action_feedback_comes_from_ui_language_bundle",
      "locales": [
        {
          "ui_language": "en",
          "expected_compact_overlay_opacity": "Overlay opacity",
          "expected_reset_done": "Defaults restored"
        },
        {
          "ui_language": "vi",
          "expected_compact_overlay_opacity": "Độ mờ overlay",
          "expected_reset_done": "Đã khôi phục mặc định"
        },
        {
          "ui_language": "ko",
          "expected_compact_overlay_opacity": "오버레이 불투명도",
          "expected_reset_done": "기본값으로 복원됨"
        }
      ]
    },
    {
      "name": "tts_method_labels_come_from_ui_language_bundle",
      "locales": [
        {
          "ui_language": "en",
          "method": "GEMINI_LIVE",
          "expected_label": "Standard (Gemini Live)",
          "expected_compact": "Standard"
        },
        {
          "ui_language": "vi",
          "method": "GEMINI_LIVE",
          "expected_label": "Xịn (Gemini Live)",
          "expected_compact": "Xịn"
        },
        {
          "ui_language": "ko",
          "method": "GEMINI_LIVE",
          "expected_label": "표준 (Gemini Live)",
          "expected_compact": "표준"
        }
      ]
    },
    {
      "name": "tools_help_copy_comes_from_ui_language_bundle",
      "locales": [
        {
          "ui_language": "en",
          "expected_language_code": "en",
          "expected_title": "Quick Guide",
          "expected_bubble_title": "Quick Settings Bubble",
          "expected_dismiss": "Got it"
        },
        {
          "ui_language": "vi",
          "expected_language_code": "vi",
          "expected_title": "Hướng dẫn sử dụng",
          "expected_bubble_title": "Bong bóng Quick Settings",
          "expected_dismiss": "Đã hiểu"
        },
        {
          "ui_language": "ko",
          "expected_language_code": "ko",
          "expected_title": "사용 가이드",
          "expected_bubble_title": "Quick Settings 버블",
          "expected_dismiss": "알겠습니다"
        }
      ]
    },
    {
      "name": "mobile_branding_uses_windows_app_icon_pair",
      "expected_dark_asset": "assets/app-icon-small.png",
      "expected_light_asset": "assets/app-icon-small-light.png"
    },
    {
      "name": "tools_tab_owns_scroll_and_uses_viewport_footer",
      "section": "TOOLS",
      "expected_outer_scroll_owner": false,
      "expected_viewport_footer": true
    },
    {
      "name": "nested_carousel_locks_outer_pager_for_the_full_touch_when_inner_scroll_exists",
      "touch_cases": [
        {
          "can_scroll_backward": true,
          "can_scroll_forward": false,
          "expected_lock": true
        },
        {
          "can_scroll_backward": false,
          "can_scroll_forward": true,
          "expected_lock": true
        },
        {
          "can_scroll_backward": true,
          "can_scroll_forward": true,
          "expected_lock": true
        },
        {
          "can_scroll_backward": false,
          "can_scroll_forward": false,
          "expected_lock": false
        }
      ]
    }
  ]
}
