{
  "version": 4,
  "cases": [
    {
      "name": "help_index_context",
      "url": "https://raw.githubusercontent.com/nganlinh4/screen-goated-toolbox/main/help-index.json",
      "top_k": 20,
      "empty_terms_use_first_chunks": true,
      "score_inputs": [
        "path",
        "text"
      ],
      "path_match_boost": 3.0
    },
    {
      "name": "search_ranking_uses_non_overlapping_matches",
      "question": "aa",
      "chunks": [
        {
          "id": "overlap-heavy",
          "path": "docs/one.txt",
          "text": "aaaaa"
        },
        {
          "id": "three-clear-matches",
          "path": "docs/two.txt",
          "text": "aa aa aa"
        }
      ],
      "expected_top_ids": [
        "three-clear-matches",
        "overlap-heavy"
      ]
    },
    {
      "name": "android_settings_entry_surface",
      "section": "SETTINGS",
      "entry_surface": "material3_dialog_or_sheet",
      "answer_surface": "floating_overlay_result",
      "platform_prompt_scope": "android",
      "question_surface_differs_from_windows": true
    },
    {
      "name": "android_overlay_permission_recovery",
      "missing_overlay_permission": "launch_system_overlay_settings",
      "pending_question_preserved": true,
      "retry_overlay_after_permission_granted": true,
      "fallback_answer_surface": "none"
    },
    {
      "name": "model_chain",
      "primary": "gemini-3.5-flash-lite",
      "fallback": "gemini-3.1-flash-lite",
      "max_output_tokens": 4096,
      "temperature": 0.7,
      "thinking_config": {
        "gemini-3.5-flash-lite": {
          "thinkingLevel": "MINIMAL"
        },
        "gemini-3.1-flash-lite": {
          "thinkingLevel": "MINIMAL"
        }
      }
    },
    {
      "name": "long_lived_request_behavior",
      "use_dedicated_help_assistant_clients": true,
      "allow_large_help_index_fetches": true,
      "allow_long_generation_latency": true
    },
    {
      "name": "prompt_contract",
      "question_language_answer": true,
      "markdown_output": true,
      "forbid_made_up_information": true,
      "forbid_source_code_framing": true,
      "require_locale_correct_ui_terms": true
    }
  ]
}
