# Normalize text files in the index, then use explicit EOL rules where needed.
* text=auto

# Source code and common config/web assets should stay LF across platforms.
*.rs text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows-native scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.bmp binary
*.ico binary
*.ttf binary
*.otf binary
*.dll binary
*.exe binary
*.zip binary
*.jar binary
*.so binary
*.dylib binary
