        74 => Some("J"),
        75 => Some("K"),
        76 => Some("L"),
        77 => Some("M"),
        78 => Some("N"),
        79 => Some("O"),
        80 => Some("P"),
        81 => Some("Q"),
        82 => Some("R"),
        83 => Some("S"),
        84 => Some("T"),
        85 => Some("U"),
        86 => Some("V"),
        87 => Some("W"),
        88 => Some("X"),
        89 => Some("Y"),
        90 => Some("Z"),
        96 => Some("Num0"),
        97 => Some("Num1"),
        98 => Some("Num2"),
        99 => Some("Num3"),
        100 => Some("Num4"),
        101 => Some("Num5"),
        102 => Some("Num6"),
        103 => Some("Num7"),
        104 => Some("Num8"),
        105 => Some("Num9"),
        106 => Some("*"),
        107 => Some("+"),
        109 => Some("-"),
        110 => Some("."),
        111 => Some("/"),
        112 => Some("F1"),
