          trimSegments: [{
            id: crypto.randomUUID(),
            startTime: 0,
            endTime: duration,
          }],
          zoomKeyframes: [],
          textSegments: [],
          keystrokeMode: 'off',
          keystrokeDelaySec: DEFAULT_KEYSTROKE_DELAY_SEC,
          keystrokeEvents: [],
          keyboardVisibilitySegments: [],
          keyboardMouseVisibilitySegments: [],
          keystrokeOverlay: { x: 50, y: 100, scale: 1 },
