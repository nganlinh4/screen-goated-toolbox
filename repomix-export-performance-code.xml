    pub(crate) splash: Option<crate::gui::splash::SplashScreen>,
    pub(crate) fade_in_start: Option<f64>,

    // 0 = Init/Offscreen, 1 = Early init, 2..34 = Wait, 35 = Create splash, 36 = Show window, 37 = Ready
