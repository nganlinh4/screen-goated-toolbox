        144 => Some("NumLock"),
        145 => Some("ScrollLock"),
        19 => Some("Pause"),
        160 | 161 => Some("Shift"),
        162 | 163 => Some("Ctrl"),
        164 | 165 => Some("Alt"),
        48 => Some("0"),
        49 => Some("1"),
        50 => Some("2"),
        51 => Some("3"),
        52 => Some("4"),
        53 => Some("5"),
        54 => Some("6"),
        55 => Some("7"),
        56 => Some("8"),
        57 => Some("9"),
        65 => Some("A"),
        66 => Some("B"),
        67 => Some("C"),
        68 => Some("D"),
